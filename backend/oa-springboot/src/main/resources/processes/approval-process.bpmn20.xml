<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             expressionLanguage="http://www.w3.org/1999/XPath"
             targetNamespace="http://flowable.org/test"
             id="Definitions_approvalProcess">

  <!-- 通用审批工作流：支持单签、并行会签、串签三种模式 -->
  <process id="approvalProcess" name="OA系统通用审批工作流" isExecutable="true">

    <!-- 1. 开始事件 -->
    <startEvent id="StartEvent_approval" name="审批流程开始"/>

    <!-- 连接到规则判断 -->
    <sequenceFlow id="flow_start_to_rule_eval"
                  sourceRef="StartEvent_approval"
                  targetRef="RuleEvaluationTask"/>

    <!-- 2. 业务规则任务：评估审批规则，确定审批方式和所需角色（Flowable 驱动） -->
    <serviceTask id="RuleEvaluationTask"
                 name="评估审批规则"
                 flowable:delegateExpression="${approvalRuleEvaluationDelegate}"/>

    <sequenceFlow id="flow_rule_eval_to_role_resolve"
                  sourceRef="RuleEvaluationTask"
                  targetRef="RoleResolverTask"/>

    <!-- 3. 审批角色解析任务：解析出实际的审批人列表 -->
    <serviceTask id="RoleResolverTask"
                 name="解析审批角色"
                 flowable:delegateExpression="${approvalRoleResolverDelegate}"/>

    <sequenceFlow id="flow_role_resolve_to_gateway"
                  sourceRef="RoleResolverTask"
                  targetRef="SignTypeGateway"/>

    <!-- 3. 审批方式网关：根据 signType 分流到不同的审批方式 -->
    <exclusiveGateway id="SignTypeGateway" name="按审批方式分流"/>

    <!-- ========== 分支 1: 单签 ========== -->
    <sequenceFlow id="flow_gateway_to_single"
                  sourceRef="SignTypeGateway"
                  targetRef="SingleApprovalTask">
      <conditionExpression xsi:type="tFormalExpression">${signType == 'SINGLE'}</conditionExpression>
    </sequenceFlow>

    <!-- 单签任务 -->
    <userTask id="SingleApprovalTask"
              name="单级审批"
              flowable:assignee="${approverList[0]}">
      <extensionElements>
        <flowable:taskListener event="create"
                               delegateExpression="${approvalTaskListener}"/>
      </extensionElements>
    </userTask>

    <sequenceFlow id="flow_single_to_result_check"
                  sourceRef="SingleApprovalTask"
                  targetRef="SingleResultGateway"/>

    <!-- 单签结果判断 -->
    <exclusiveGateway id="SingleResultGateway" name="单签审批结果"/>

    <sequenceFlow id="flow_single_approved"
                  sourceRef="SingleResultGateway"
                  targetRef="EndEvent_Approved">
      <conditionExpression xsi:type="tFormalExpression">${outcome == 'APPROVE'}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="flow_single_rejected"
                  sourceRef="SingleResultGateway"
                  targetRef="EndEvent_Rejected">
      <conditionExpression xsi:type="tFormalExpression">${outcome == 'REJECT'}</conditionExpression>
    </sequenceFlow>

    <!-- ========== 分支 2: 并行会签 ========== -->
    <sequenceFlow id="flow_gateway_to_parallel"
                  sourceRef="SignTypeGateway"
                  targetRef="ParallelApprovalTask">
      <conditionExpression xsi:type="tFormalExpression">${signType == 'PARALLEL'}</conditionExpression>
    </sequenceFlow>

    <!-- 并行会签任务：所有审批人并行审批，任意一人驳回则整单驳回 -->
    <userTask id="ParallelApprovalTask"
              name="并行会签审批"
              flowable:assignee="${approver}">
      <extensionElements>
        <flowable:taskListener event="create"
                               delegateExpression="${approvalTaskListener}"/>
        <flowable:taskListener event="complete"
                               delegateExpression="${parallelApprovalCompleteListener}"/>
      </extensionElements>
      <multiInstanceLoopCharacteristics isSequential="false"
                                        flowable:collection="approverList"
                                        flowable:elementVariable="approver">
        <completionCondition xsi:type="tFormalExpression">
          ${nrOfCompletedInstances == nrOfInstances or (isAllApproved != null and isAllApproved == false)}
        </completionCondition>
      </multiInstanceLoopCharacteristics>
    </userTask>

    <sequenceFlow id="flow_parallel_to_result_check"
                  sourceRef="ParallelApprovalTask"
                  targetRef="ParallelResultGateway"/>

    <!-- 并行会签结果判断 -->
    <exclusiveGateway id="ParallelResultGateway" name="会签审批结果"/>

    <sequenceFlow id="flow_parallel_all_approved"
                  sourceRef="ParallelResultGateway"
                  targetRef="EndEvent_Approved">
      <conditionExpression xsi:type="tFormalExpression">${isAllApproved == null or isAllApproved == true}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="flow_parallel_any_rejected"
                  sourceRef="ParallelResultGateway"
                  targetRef="EndEvent_Rejected">
      <conditionExpression xsi:type="tFormalExpression">${isAllApproved != null and isAllApproved == false}</conditionExpression>
    </sequenceFlow>

    <!-- ========== 分支 3: 会签后串签 ========== -->
    <sequenceFlow id="flow_gateway_to_serial_after_parallel"
                  sourceRef="SignTypeGateway"
                  targetRef="FirstLevelParallelTask">
      <conditionExpression xsi:type="tFormalExpression">${signType == 'SERIAL_AFTER_PARALLEL'}</conditionExpression>
    </sequenceFlow>

    <!-- 第一级：并行会签 -->
    <userTask id="FirstLevelParallelTask"
              name="第一级并行会签"
              flowable:assignee="${approver}">
      <extensionElements>
        <flowable:taskListener event="create"
                               delegateExpression="${approvalTaskListener}"/>
        <flowable:taskListener event="complete"
                               delegateExpression="${parallelApprovalCompleteListener}"/>
      </extensionElements>
      <multiInstanceLoopCharacteristics isSequential="false"
                                        flowable:collection="approverList"
                                        flowable:elementVariable="approver">
        <completionCondition xsi:type="tFormalExpression">
          ${nrOfCompletedInstances == nrOfInstances or (isAllApproved != null and isAllApproved == false)}
        </completionCondition>
      </multiInstanceLoopCharacteristics>
    </userTask>

    <sequenceFlow id="flow_first_level_to_result_check"
                  sourceRef="FirstLevelParallelTask"
                  targetRef="FirstLevelResultGateway"/>

    <!-- 第一级结果判断 -->
    <exclusiveGateway id="FirstLevelResultGateway" name="第一级会签结果"/>

    <!-- 第一级任意人驳回，直接拒绝 -->
    <sequenceFlow id="flow_first_level_rejected"
                  sourceRef="FirstLevelResultGateway"
                  targetRef="EndEvent_Rejected">
      <conditionExpression xsi:type="tFormalExpression">${isAllApproved != null and isAllApproved == false}</conditionExpression>
    </sequenceFlow>

    <!-- 第一级全部通过，进入第二级 -->
    <sequenceFlow id="flow_first_level_approved_to_second"
                  sourceRef="FirstLevelResultGateway"
                  targetRef="SecondLevelSerialTask">
      <conditionExpression xsi:type="tFormalExpression">${isAllApproved == null or isAllApproved == true}</conditionExpression>
    </sequenceFlow>

    <!-- 第二级：串签（单个总经理最后审批） -->
    <userTask id="SecondLevelSerialTask"
              name="第二级串签审批"
              flowable:assignee="${secondLevelApprover}">
      <extensionElements>
        <flowable:taskListener event="create"
                               delegateExpression="${approvalTaskListener}"/>
      </extensionElements>
    </userTask>

    <sequenceFlow id="flow_second_level_to_result_check"
                  sourceRef="SecondLevelSerialTask"
                  targetRef="SecondLevelResultGateway"/>

    <!-- 第二级结果判断 -->
    <exclusiveGateway id="SecondLevelResultGateway" name="第二级审批结果"/>

    <sequenceFlow id="flow_second_level_approved"
                  sourceRef="SecondLevelResultGateway"
                  targetRef="EndEvent_Approved">
      <conditionExpression xsi:type="tFormalExpression">${outcome == 'APPROVE'}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="flow_second_level_rejected"
                  sourceRef="SecondLevelResultGateway"
                  targetRef="EndEvent_Rejected">
      <conditionExpression xsi:type="tFormalExpression">${outcome == 'REJECT'}</conditionExpression>
    </sequenceFlow>

    <!-- 4. 结束事件 -->
    <endEvent id="EndEvent_Approved" name="审批通过">
      <extensionElements>
        <flowable:executionListener event="end"
                                     delegateExpression="${approvalProcessEndListener}"/>
      </extensionElements>
    </endEvent>
    <endEvent id="EndEvent_Rejected" name="审批拒绝">
      <extensionElements>
        <flowable:executionListener event="end"
                                     delegateExpression="${approvalProcessEndListener}"/>
      </extensionElements>
    </endEvent>

  </process>

  <!-- ========== BPMN Diagram（图形坐标，由 bpmn-js 渲染需要） ========== -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_approvalProcess">
    <bpmndi:BPMNPlane bpmnElement="approvalProcess" id="BPMNPlane_approvalProcess">

      <!-- Start Event -->
      <bpmndi:BPMNShape id="shape_StartEvent_approval" bpmnElement="StartEvent_approval">
        <omgdc:Bounds x="100" y="180" width="36" height="36" />
      </bpmndi:BPMNShape>

      <!-- Rule Evaluation Task -->
      <bpmndi:BPMNShape id="shape_RuleEvaluationTask" bpmnElement="RuleEvaluationTask">
        <omgdc:Bounds x="190" y="155" width="120" height="80" />
      </bpmndi:BPMNShape>

      <!-- Role Resolver Task -->
      <bpmndi:BPMNShape id="shape_RoleResolverTask" bpmnElement="RoleResolverTask">
        <omgdc:Bounds x="360" y="155" width="120" height="80" />
      </bpmndi:BPMNShape>

      <!-- SignType Gateway -->
      <bpmndi:BPMNShape id="shape_SignTypeGateway" bpmnElement="SignTypeGateway">
        <omgdc:Bounds x="530" y="168" width="50" height="50" />
      </bpmndi:BPMNShape>

      <!-- SINGLE branch -->
      <bpmndi:BPMNShape id="shape_SingleApprovalTask" bpmnElement="SingleApprovalTask">
        <omgdc:Bounds x="640" y="30" width="120" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_SingleResultGateway" bpmnElement="SingleResultGateway">
        <omgdc:Bounds x="820" y="43" width="50" height="50" />
      </bpmndi:BPMNShape>

      <!-- PARALLEL branch -->
      <bpmndi:BPMNShape id="shape_ParallelApprovalTask" bpmnElement="ParallelApprovalTask">
        <omgdc:Bounds x="640" y="155" width="120" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_ParallelResultGateway" bpmnElement="ParallelResultGateway">
        <omgdc:Bounds x="820" y="168" width="50" height="50" />
      </bpmndi:BPMNShape>

      <!-- SERIAL_AFTER_PARALLEL branch -->
      <bpmndi:BPMNShape id="shape_FirstLevelParallelTask" bpmnElement="FirstLevelParallelTask">
        <omgdc:Bounds x="640" y="280" width="120" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_FirstLevelResultGateway" bpmnElement="FirstLevelResultGateway">
        <omgdc:Bounds x="820" y="293" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_SecondLevelSerialTask" bpmnElement="SecondLevelSerialTask">
        <omgdc:Bounds x="930" y="293" width="120" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_SecondLevelResultGateway" bpmnElement="SecondLevelResultGateway">
        <omgdc:Bounds x="1100" y="306" width="50" height="50" />
      </bpmndi:BPMNShape>

      <!-- End Events -->
      <bpmndi:BPMNShape id="shape_EndEvent_Approved" bpmnElement="EndEvent_Approved">
        <omgdc:Bounds x="970" y="36" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_EndEvent_Rejected" bpmnElement="EndEvent_Rejected">
        <omgdc:Bounds x="1200" y="299" width="36" height="36" />
      </bpmndi:BPMNShape>

      <!-- Sequence Flows -->
      <bpmndi:BPMNEdge id="edge_start_to_rule" bpmnElement="flow_start_to_rule_eval">
        <omgdi:waypoint x="136" y="198" />
        <omgdi:waypoint x="190" y="195" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_rule_to_role" bpmnElement="flow_rule_eval_to_role_resolve">
        <omgdi:waypoint x="310" y="195" />
        <omgdi:waypoint x="360" y="195" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_role_to_gateway" bpmnElement="flow_role_resolve_to_gateway">
        <omgdi:waypoint x="480" y="195" />
        <omgdi:waypoint x="530" y="193" />
      </bpmndi:BPMNEdge>

      <!-- SINGLE flows -->
      <bpmndi:BPMNEdge id="edge_gateway_to_single" bpmnElement="flow_gateway_to_single">
        <omgdi:waypoint x="555" y="168" />
        <omgdi:waypoint x="555" y="70" />
        <omgdi:waypoint x="640" y="70" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_single_to_result" bpmnElement="flow_single_to_result_check">
        <omgdi:waypoint x="760" y="70" />
        <omgdi:waypoint x="820" y="68" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_single_approved" bpmnElement="flow_single_approved">
        <omgdi:waypoint x="870" y="68" />
        <omgdi:waypoint x="970" y="54" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_single_rejected" bpmnElement="flow_single_rejected">
        <omgdi:waypoint x="845" y="93" />
        <omgdi:waypoint x="845" y="430" />
        <omgdi:waypoint x="1218" y="430" />
        <omgdi:waypoint x="1218" y="335" />
      </bpmndi:BPMNEdge>

      <!-- PARALLEL flows -->
      <bpmndi:BPMNEdge id="edge_gateway_to_parallel" bpmnElement="flow_gateway_to_parallel">
        <omgdi:waypoint x="580" y="193" />
        <omgdi:waypoint x="640" y="195" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_parallel_to_result" bpmnElement="flow_parallel_to_result_check">
        <omgdi:waypoint x="760" y="195" />
        <omgdi:waypoint x="820" y="193" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_parallel_approved" bpmnElement="flow_parallel_all_approved">
        <omgdi:waypoint x="870" y="193" />
        <omgdi:waypoint x="1006" y="193" />
        <omgdi:waypoint x="1006" y="72" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_parallel_rejected" bpmnElement="flow_parallel_any_rejected">
        <omgdi:waypoint x="845" y="218" />
        <omgdi:waypoint x="845" y="430" />
        <omgdi:waypoint x="1218" y="430" />
        <omgdi:waypoint x="1218" y="335" />
      </bpmndi:BPMNEdge>

      <!-- SERIAL_AFTER_PARALLEL flows -->
      <bpmndi:BPMNEdge id="edge_gateway_to_serial" bpmnElement="flow_gateway_to_serial_after_parallel">
        <omgdi:waypoint x="555" y="218" />
        <omgdi:waypoint x="555" y="320" />
        <omgdi:waypoint x="640" y="320" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_first_level_to_result" bpmnElement="flow_first_level_to_result_check">
        <omgdi:waypoint x="760" y="320" />
        <omgdi:waypoint x="820" y="318" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_first_level_rejected" bpmnElement="flow_first_level_rejected">
        <omgdi:waypoint x="845" y="343" />
        <omgdi:waypoint x="845" y="430" />
        <omgdi:waypoint x="1218" y="430" />
        <omgdi:waypoint x="1218" y="335" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_first_level_approved" bpmnElement="flow_first_level_approved_to_second">
        <omgdi:waypoint x="870" y="318" />
        <omgdi:waypoint x="930" y="333" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_second_to_result" bpmnElement="flow_second_level_to_result_check">
        <omgdi:waypoint x="1050" y="333" />
        <omgdi:waypoint x="1100" y="331" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_second_approved" bpmnElement="flow_second_level_approved">
        <omgdi:waypoint x="1150" y="331" />
        <omgdi:waypoint x="1150" y="54" />
        <omgdi:waypoint x="1006" y="54" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_second_rejected" bpmnElement="flow_second_level_rejected">
        <omgdi:waypoint x="1125" y="356" />
        <omgdi:waypoint x="1125" y="430" />
        <omgdi:waypoint x="1218" y="430" />
        <omgdi:waypoint x="1218" y="335" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</definitions>
