<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/DMN/20151101/dmn.xsd"
             id="overtimeRuleDecisions"
             name="加班单审批规则"
             namespace="http://camunda.org/schema/1.0/dmn"
             exporter="Flowable"
             exporterVersion="6.8.0">

  <!-- 加班单审批规则决策表
       规则：风险低，不分级
       - 所有加班单：本部门经理单签
  -->
  <decision id="overtimeRuleDecision" name="加班单规则决策表">
    <decisionTable id="overtimeDecisionTable">
      
      <input id="overtimeDummyInput" label="占位字段">
        <inputExpression id="overtimeDummyExpression" typeRef="string">
          <text>approvalType</text>
        </inputExpression>
      </input>

      <output id="overtimeRequiredRolesOutput" label="需要的审批角色" name="requiredRoles" typeRef="string"/>
      <output id="overtimeSignTypeOutput" label="审批方式" name="signType" typeRef="string"/>

      <!-- 规则：所有加班单 - 部门经理单签 -->
      <rule id="overtimeRule1">
        <inputEntry id="overtimeInput1">
          <text>"overtime"</text>
        </inputEntry>
        <outputEntry id="overtimeRolesOutput1">
          <text>"DEPT_MANAGER"</text>
        </outputEntry>
        <outputEntry id="overtimeSignTypeOutput1">
          <text>"SINGLE"</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

</definitions>
